<idea-plugin>
	<id>biz.paluch.dependency-assistant</id>

	<name>Dependency Assistant</name>

	<vendor url="https://github.com/mp911de/dependency-assistant">Mark Paluch</vendor>
	<category>Build Tools</category>

	<description><![CDATA[
		<p>
			Provides assisted upgrading of Maven and Gradle dependencies in your IDE. The plugin highlights dependency declarations for newer versions and offers a controlled path to apply updates without replacing your own judgment about when to upgrade.
		</p>

		The support includes:
		<ul>
  <li>Scanning of <code>pom.xml</code> (Maven) and <code>build.gradle(.kts)</code>, <code>gradle.properties</code>,
      <code>settings.gradle(.kts)</code>, and <code>gradle/libs.versions.toml</code> (Gradle)</li>
  <li>Determining version update candidates against remote Maven repositories</li>
  <li>Selection of dependencies and plugins to update</li>
  <li>Supports Maven Central and custom repositories</li>
</ul>

		<h3>Maven</h3>
		<ul>
			<li>Open <code>pom.xml</code> in the editor.</li>
			<li>Use the intention action (light bulb) on a dependency or plugin version to check for updates.</li>
			<li>Or use the menu action <strong>Tools | Update Maven Plugins and Dependencies</strong>.</li>
		</ul>

		<h3>Gradle</h3>
		<ul>
			<li>Open a Gradle build file (<code>build.gradle</code>, <code>build.gradle.kts</code>, <code>gradle.properties</code>,
    or <code>libs.versions.toml</code>) in the editor.</li>
			<li>Use the intention action (light bulb) to check for updates.</li>
			<li>Or use <strong>Tools | Update Gradle Dependencies</strong>.</li>
		</ul>

		<p>
			<a href="https://github.com/mp911de/dependency-assistant">Source and issues: mp911de/dependency-assistant</a>
		</p>
	]]></description>


	<depends>com.intellij.modules.xml</depends>
	<depends>com.intellij.modules.java</depends>
	<depends optional="true" config-file="maven.xml">
		org.jetbrains.idea.maven
	</depends>
	<depends optional="true" config-file="kotlin.xml">
		org.jetbrains.kotlin
	</depends>
	<depends optional="true" config-file="gradle.xml">
		org.jetbrains.plugins.gradle
	</depends>
	<depends optional="true" config-file="yaml.xml">
		org.jetbrains.plugins.yaml
	</depends>
	<depends optional="true" config-file="github.xml">org.jetbrains.plugins.github</depends>
	<depends optional="true" config-file="git.xml">Git4Idea</depends>
	<depends optional="true" config-file="npm.xml">com.intellij.modules.json</depends>

	<resource-bundle>messages.MessageBundle</resource-bundle>

	<extensionPoints>
		<extensionPoint qualifiedName="biz.paluch.dap.assistant"
		                interface="biz.paluch.dap.DependencyAssistant"
		                dynamic="true"/>
	</extensionPoints>

	<applicationListeners>
		<listener class="biz.paluch.dap.support.FlushStateOnSave"
		          topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
	</applicationListeners>

	<extensions defaultExtensionNs="org.jetbrains.kotlin">
		<supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
	</extensions>

	<extensions defaultExtensionNs="com.intellij">
		<postStartupActivity implementation="biz.paluch.dap.support.PostStartup"/>
		<notificationGroup id="biz.paluch.dependency-assistant.releases"
		                   displayType="BALLOON"
		                   bundle="messages.MessageBundle" key="plugin.name"/>
		<notificationGroup id="biz.paluch.dependency-assistant.releases-sticky"
		                   displayType="STICKY_BALLOON"
		                   bundle="messages.MessageBundle" key="plugin.name"/>
		<additionalTextAttributes scheme="Default"
		                          file="colorSchemes/DependencyAssistantDefault.xml"/>
		<additionalTextAttributes scheme="Darcula"
		                          file="colorSchemes/DependencyAssistantDarcula.xml"/>

		<colorSettingsPage
				implementation="biz.paluch.dap.severity.DependencyAssistantColorSettingsPage"/>
		<projectService
				serviceImplementation="biz.paluch.dap.state.DependencyAssistantService"/>
		<severitiesProvider
				implementation="biz.paluch.dap.severity.DependencyAssistantSeverities"/>
		<platform.backend.documentation.psiTargetProvider
				implementation="biz.paluch.dap.support.DependencyDocumentationProvider"/>
		<intentionAction>
			<category>Dependency Assistant</category>
			<className>biz.paluch.dap.support.UpgradeDependenciesIntention</className>
		</intentionAction>
	</extensions>

	<actions>
		<action id="biz.paluch.dap.UpdateDependencies"
		        class="biz.paluch.dap.support.UpdateDependenciesAction"
		        text="Update Dependencies…">
			<add-to-group group-id="ToolsMenu" anchor="last"/>
		</action>
		<action id="biz.paluch.dap.RefreshReleasesMetadataAction"
		        class="biz.paluch.dap.support.RefreshReleasesMetadataAction"
		        text="Refresh Dependency Release Metadata">
			<add-to-group group-id="ToolsMenu" anchor="last"/>
		</action>
	</actions>
</idea-plugin>
