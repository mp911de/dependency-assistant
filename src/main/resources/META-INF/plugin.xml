<idea-plugin>
	<id>biz.paluch.dependency-assistant</id>

	<name>Dependency Assistant</name>

	<vendor url="https://github.com/mp911de/dependency-assistant">Mark Paluch</vendor>
	<category>Build Tools</category>

	<description><![CDATA[
		<p>
			Provides assisted upgrading of Maven, Gradle, GitHub Actions, NPM, and Antora dependencies, plus Maven and Gradle wrapper properties, in your IDE. The plugin highlights dependency declarations for newer versions and offers a controlled path to apply updates without replacing your own judgment about when to upgrade.
		</p>

		The support includes:
		<ul>
  <li>Scanning of <code>pom.xml</code> (Maven), <code>build.gradle(.kts)</code>, <code>gradle.properties</code>,
      <code>settings.gradle(.kts)</code>, <code>gradle/libs.versions.toml</code> (Gradle), <code>action.yaml</code> and workflows (GitHub Action), <code>package.json</code> (NPM), <code>antora-playbook.yml</code> (Antora)</li>
  <li>Determining version update candidates against remote repositories</li>
  <li>Selection of dependencies and plugins to update</li>
  <li>Supports Maven Central, custom Maven repositories, npmjs, and GitHub as release metadata sources</li>
  <li>Shows Package Checker vulnerability information for Maven and npm packages when that IDE service is available</li>
</ul>

		<h3>First Steps</h3>
		<ul>
			<li>Open a build file in the editor.</li>
			<li>Use the intention action (light bulb) on a dependency or plugin version to check for updates.</li>
			<li>Or use the menu action <strong>Tools | Dependency Assistant | Update Dependencies…</strong>.</li>
		</ul>

		<p>
			<a href="https://github.com/mp911de/dependency-assistant">Source and issues: mp911de/dependency-assistant</a>
		</p>
	]]></description>

	<depends>com.intellij.modules.xml</depends>
	<depends>com.intellij.modules.vcs</depends>
	<depends optional="true" config-file="maven.xml">org.jetbrains.idea.maven</depends>
	<depends optional="true" config-file="kotlin.xml">org.jetbrains.kotlin</depends>
	<depends optional="true" config-file="gradle.xml">org.jetbrains.plugins.gradle</depends>
	<depends optional="true" config-file="yaml.xml">org.jetbrains.plugins.yaml</depends>
	<depends optional="true" config-file="github.xml">org.jetbrains.plugins.github</depends>
	<depends optional="true" config-file="git.xml">Git4Idea</depends>
	<depends optional="true" config-file="json.xml">com.intellij.modules.json</depends>
	<depends optional="true" config-file="package-checker.xml">
		org.jetbrains.security.package-checker
	</depends>

	<resource-bundle>messages.MessageBundle</resource-bundle>

	<extensionPoints>
		<extensionPoint qualifiedName="biz.paluch.dap.assistant"
		                interface="biz.paluch.dap.DependencyAssistant"
		                dynamic="true"/>
		<extensionPoint qualifiedName="biz.paluch.dap.vulnerabilitySource"
		                interface="biz.paluch.dap.checker.VulnerabilitySource"
		                dynamic="true"/>
		<extensionPoint qualifiedName="biz.paluch.dap.bomLocator"
		                interface="biz.paluch.dap.artifact.BomLocator"
		                dynamic="true"/>
		<extensionPoint qualifiedName="biz.paluch.dap.ticketSystem"
		                interface="biz.paluch.dap.ticket.TicketSystemProvider"
		                dynamic="true"/>
	</extensionPoints>

	<extensions defaultExtensionNs="biz.paluch.dap">
		<bomLocator implementation="biz.paluch.dap.maven.SimpleMavenBomLocator"/>
		<ticketSystem implementation="biz.paluch.dap.plan.InMemoryTicketSystemProvider"/>
	</extensions>

	<extensions defaultExtensionNs="org.jetbrains.kotlin">
		<supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
	</extensions>

	<extensions defaultExtensionNs="com.intellij">
		<fileTemplateGroup implementation="biz.paluch.dap.plan.UpgradePlanTemplateGroup"/>
		<toolWindow id="Upgrade Plan" anchor="bottom" doNotActivateOnStart="true"
		            factoryClass="biz.paluch.dap.plan.UpgradePlanToolWindowFactory"
		            icon="biz.paluch.dap.DependencyAssistantIcons.TOOL_WINDOW_UPGRADE_PLAN"/>
		<postStartupActivity
				implementation="biz.paluch.dap.assistant.action.PostStartup"/>
		<actionOnSave implementation="biz.paluch.dap.assistant.action.FlushStateOnSave"/>
		<psi.treeChangeListener
				implementation="biz.paluch.dap.assistant.action.FlushStateOnEdit"/>
		<notificationGroup id="biz.paluch.dependency-assistant"
		                   displayType="NONE"
		                   bundle="messages.MessageBundle" key="plugin.name"/>
		<notificationGroup id="biz.paluch.dependency-assistant.releases-sticky"
		                   displayType="STICKY_BALLOON"
		                   bundle="messages.MessageBundle" key="notification.refresh-release-metadata"/>
		<notificationGroup id="biz.paluch.dependency-assistant.errors"
		                   displayType="BALLOON"
	                   bundle="messages.MessageBundle" key="UpdateBuildFile.notification.error.title"/>
		<notificationGroup id="biz.paluch.dependency-assistant.upgrades"
		                   displayType="NONE"
		                   isLogByDefault="true"
		                   bundle="messages.MessageBundle" key="notification.dependencies-updates"/>
		<notificationGroup id="biz.paluch.dependency-assistant.plan"
		                   displayType="BALLOON"
		                   bundle="messages.MessageBundle" key="plan.notification.group"/>
		<additionalTextAttributes scheme="Default"
		                          file="colorSchemes/DependencyAssistantDefault.xml"/>
		<additionalTextAttributes scheme="Darcula"
		                          file="colorSchemes/DependencyAssistantDarcula.xml"/>
		<colorSettingsPage
				implementation="biz.paluch.dap.severity.DependencyAssistantColorSettingsPage"/>
		<projectService
				serviceImplementation="biz.paluch.dap.state.StateService"/>
		<projectService
				serviceImplementation="biz.paluch.dap.rule.DependencyfileService"/>
		<severitiesProvider
				implementation="biz.paluch.dap.severity.DependencyAssistantSeverities"/>
		<platform.backend.documentation.psiTargetProvider
				implementation="biz.paluch.dap.assistant.documentation.DependencyDocumentationProvider"/>
		<platform.backend.documentation.lookupElementTargetProvider
				implementation="biz.paluch.dap.assistant.documentation.ReleaseLookupDocumentationProvider"/>
		<platform.backend.documentation.linkHandler
				implementation="biz.paluch.dap.assistant.documentation.DependencyUpgradeLinkHandler"/>
		<annotator language="Properties"
		           implementationClass="biz.paluch.dap.assistant.editor.DependencyVersionAnnotator"/>
		<localInspection id="dap.version-drift"
				bundle="messages.MessageBundle"
				groupKey="plugin.name"
				key="inspection.version-drift.display-name"
				level="WARNING"
				enabledByDefault="true"
				         implementationClass="biz.paluch.dap.assistant.editor.DependencyVersionDriftInspection"/>
		<localInspection id="dap.dependency-rule"
		                 bundle="messages.MessageBundle"
		                 groupKey="plugin.name"
		                 key="inspection.dependency-rule.display-name"
		                 level="WARNING"
		                 enabledByDefault="true"
		                 implementationClass="biz.paluch.dap.assistant.editor.DependencyRuleInspection"/>
		<intentionAction id="dap.upgrade.dependencies">
			<language/>
			<skipBeforeAfter>true</skipBeforeAfter>
			<categoryKey>intention.dap.category</categoryKey>
			<bundleName>messages.MessageBundle</bundleName>
			<className>biz.paluch.dap.assistant.action.UpgradeDependenciesIntention
			</className>
		</intentionAction>
	</extensions>

	<actions>
		<group id="DependencyAssistant.UpgradePlan.Toolbar">
			<action id="DependencyAssistant.UpgradePlan.ApplyAll"
			        class="biz.paluch.dap.plan.ApplyAllAction"
			        icon="biz.paluch.dap.DependencyAssistantIcons.PLAN_APPLY_ALL"/>
			<action id="DependencyAssistant.UpgradePlan.ApplyAllAndCommit"
			        class="biz.paluch.dap.plan.ApplyAllAndCommitAction"
			        icon="AllIcons.Actions.Commit"/>
			<action id="DependencyAssistant.UpgradePlan.PreviewChanges"
			        class="biz.paluch.dap.plan.PreviewChangesAction"
			        icon="AllIcons.Actions.Preview"/>
			<separator/>
			<action id="DependencyAssistant.UpgradePlan.CreateTickets"
			        class="biz.paluch.dap.plan.CreateTicketsAction"
			        icon="biz.paluch.dap.DependencyAssistantIcons.PLAN_CREATE_TICKETS"/>
			<separator/>
			<action id="DependencyAssistant.UpgradePlan.Refresh"
			        class="biz.paluch.dap.plan.RefreshPlanAction"
			        icon="AllIcons.Actions.Refresh"/>
			<action id="DependencyAssistant.UpgradePlan.Discard"
			        class="biz.paluch.dap.plan.DiscardPlanAction"
			        icon="AllIcons.Actions.GC"/>
		</group>
		<group id="DependencyAssistant.UpgradePlan.Popup">
			<reference ref="DependencyAssistant.UpgradePlan.PreviewChanges"/>
			<reference ref="EditSource"/>
			<action id="DependencyAssistant.UpgradePlan.FindUsages"
			        class="biz.paluch.dap.plan.FindUsagesAction"
			        icon="AllIcons.Actions.Find"/>
			<separator/>
			<reference ref="DependencyAssistant.UpgradePlan.CreateTickets"/>
			<action id="DependencyAssistant.UpgradePlan.OpenTicket"
			        class="biz.paluch.dap.plan.OpenTicketInBrowserAction"
			        icon="AllIcons.General.Web"/>
			<action id="DependencyAssistant.UpgradePlan.UnlinkTicket"
			        class="biz.paluch.dap.plan.UnlinkTicketAction"
			        icon="AllIcons.General.Remove"/>
			<separator/>
			<reference ref="$Copy"/>
			<reference ref="$Paste"/>
			<reference ref="$Delete"/>
		</group>
		<group id="biz.paluch.dap.DependencyAssistant"
		       text="Dependency Assistant" popup="true"	icon="biz.paluch.dap.DependencyAssistantIcons.ICON">
			<add-to-group group-id="ToolsMenu"/>
			<action id="biz.paluch.dap.UpgradeDependencies"
			        class="biz.paluch.dap.assistant.action.UpgradeDependenciesAction"
			        text="Update Dependencies…">
				<add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
			</action>
			<action id="biz.paluch.dap.RefreshReleasesMetadataAction"
			        class="biz.paluch.dap.assistant.action.RefreshReleasesMetadataAction"
			        text="Refresh Dependency Release Metadata">
			</action>
			<separator/>
		</group>
	</actions>
</idea-plugin>
