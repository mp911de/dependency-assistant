<idea-plugin>
	<extensions defaultExtensionNs="biz.paluch.dap">
		<assistant implementation="biz.paluch.dap.npm.NpmAssistant"/>
	</extensions>

	<extensions defaultExtensionNs="com.intellij">
		<completion.contributor
				language="JSON"
				order="first"
				implementationClass="biz.paluch.dap.npm.NpmVersionCompletionContributor"/>
		<annotator language="JSON"
		           implementationClass="biz.paluch.dap.support.NewerVersionAnnotator"/>
		<codeInsight.lineMarkerProvider
				language="JSON"
				implementationClass="biz.paluch.dap.support.NewerVersionLineMarkerProvider"/>
	</extensions>
</idea-plugin>
