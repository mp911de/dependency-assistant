<idea-plugin>
	<extensions defaultExtensionNs="biz.paluch.dap">
		<assistant implementation="biz.paluch.dap.maven.MavenAssistant"/>
		<assistant implementation="biz.paluch.dap.maven.MavenExtensionsAssistant"/>
		<assistant implementation="biz.paluch.dap.maven.wrapper.MavenWrapperAssistant"/>
	</extensions>

	<extensions defaultExtensionNs="com.intellij">
		<completion.contributor
				id="dap.maven.release-version-contributor"
				language="XML"
				implementationClass="biz.paluch.dap.maven.MavenReleaseVersionCompletionContributor"/>
		<annotator language="XML"
		           implementationClass="biz.paluch.dap.assistant.editor.DependencyVersionAnnotator"/>
		<codeInsight.lineMarkerProvider
				language="XML"
				implementationClass="biz.paluch.dap.maven.MavenLineMarkerProvider"/>
		<completion.contributor
				id="dap.maven.wrapper.properties.release-version-contributor"
				language="Properties"
				order="first"
				implementationClass="biz.paluch.dap.maven.wrapper.MavenWrapperCompletionContributor"/>
		<codeInsight.lineMarkerProvider
				language="Properties"
				implementationClass="biz.paluch.dap.maven.MavenLineMarkerProvider"/>
		<localInspection id="dap.maven.wrapper.url-inspection"
				language="Properties"
				bundle="messages.MessageBundle"
				groupKey="inspection.maven-wrapper.group"
				key="inspection.maven-wrapper.display-name"
				level="WARNING"
				enabledByDefault="true"
				implementationClass="biz.paluch.dap.maven.wrapper.MavenWrapperUrlInspection"/>
		<intentionAction id="dap.maven.checksum.distribution">
			<language>Properties</language>
			<categoryKey>intention.dap.category</categoryKey>
			<bundleName>messages.MessageBundle</bundleName>
			<className>biz.paluch.dap.maven.wrapper.MavenWrapperChecksumIntention$Distribution</className>
		</intentionAction>
		<intentionAction id="dap.maven.checksum.wrapper">
			<language>Properties</language>
			<categoryKey>intention.dap.category</categoryKey>
			<bundleName>messages.MessageBundle</bundleName>
			<className>biz.paluch.dap.maven.wrapper.MavenWrapperChecksumIntention$Wrapper</className>
		</intentionAction>
	</extensions>
</idea-plugin>
