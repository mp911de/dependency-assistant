<idea-plugin>
	<extensions defaultExtensionNs="biz.paluch.dap">
		<assistant implementation="biz.paluch.dap.maven.MavenAssistant"/>
		<assistant implementation="biz.paluch.dap.maven.wrapper.MavenWrapperAssistant"/>
	</extensions>

	<extensions defaultExtensionNs="com.intellij">
		<completion.contributor
				language="XML"
				implementationClass="biz.paluch.dap.maven.MavenReleaseVersionCompletionContributor"/>
		<annotator language="XML"
		           implementationClass="biz.paluch.dap.assistant.NewerVersionAnnotator"/>
		<codeInsight.lineMarkerProvider
				language="XML"
				implementationClass="biz.paluch.dap.maven.MavenLineMarkerProvider"/>
		<completion.contributor
				language="Properties"
				order="first"
				implementationClass="biz.paluch.dap.maven.wrapper.MavenWrapperCompletionContributor"/>
		<codeInsight.lineMarkerProvider
				language="Properties"
				implementationClass="biz.paluch.dap.maven.MavenLineMarkerProvider"/>
		<localInspection
				language="Properties"
				bundle="messages.MessageBundle"
				groupKey="inspection.maven-wrapper.group"
				key="inspection.maven-wrapper.display-name"
				level="WARNING"
				enabledByDefault="true"
				implementationClass="biz.paluch.dap.maven.wrapper.MavenWrapperUrlInspection"/>
		<intentionAction>
			<language>Properties</language>
			<category>Dependency Assistant</category>
			<className>biz.paluch.dap.maven.wrapper.ChecksumIntention$Distribution
			</className>
		</intentionAction>
		<intentionAction>
			<language>Properties</language>
			<category>Dependency Assistant</category>
			<className>biz.paluch.dap.maven.wrapper.ChecksumIntention$Wrapper</className>
		</intentionAction>
	</extensions>
</idea-plugin>
