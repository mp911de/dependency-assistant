<idea-plugin>
	<extensions defaultExtensionNs="biz.paluch.dap">
		<assistant implementation="biz.paluch.dap.gradle.GradleAssistant"/>
		<assistant implementation="biz.paluch.dap.gradle.wrapper.GradleWrapperAssistant"/>
	</extensions>

	<extensions defaultExtensionNs="com.intellij">

		<postStartupActivity
				implementation="biz.paluch.dap.gradle.GradleInitService"/>
		<completion.confidence language="Groovy" order="first"
		                       implementationClass="biz.paluch.dap.gradle.GradleCompletionConfidence"/>
		<completion.confidence language="TOML" order="first"
		                       implementationClass="biz.paluch.dap.gradle.GradleCompletionConfidence"/>
		<completion.confidence language="Properties" order="first"
		                       implementationClass="biz.paluch.dap.gradle.GradleCompletionConfidence"/>
		<completion.confidence language="kotlin" order="first"
		                       implementationClass="biz.paluch.dap.gradle.GradleCompletionConfidence"/>
		<completion.contributor
				id="dap.gradle.groovy.release-version-contributor"
				language="Groovy"
				order="first"
				implementationClass="biz.paluch.dap.gradle.GroovyCompletionContributor"/>
		<completion.contributor
				id="dap.gradle.toml.release-version-contributor"
				language="TOML"
				order="first"
				implementationClass="biz.paluch.dap.gradle.TomlCompletionContributor"/>
		<completion.contributor
				id="dap.gradle.properties.release-version-contributor"
				language="Properties"
				order="first"
				implementationClass="biz.paluch.dap.gradle.GradlePropertiesCompletionContributor"/>
		<completion.contributor
				id="dap.gradle.wrapper.properties.release-version-contributor"
				language="Properties"
				order="first"
				implementationClass="biz.paluch.dap.gradle.wrapper.GradleWrapperCompletionContributor"/>
		<completion.contributor
				id="dap.gradle.kotlin.release-version-contributor"
				language="kotlin"
				order="first"
				implementationClass="biz.paluch.dap.gradle.KotlinCompletionContributor"/>
		<annotator language="Groovy"
		           implementationClass="biz.paluch.dap.assistant.editor.DependencyVersionAnnotator"/>
		<annotator language="TOML"
		           implementationClass="biz.paluch.dap.assistant.editor.DependencyVersionAnnotator"/>
		<annotator language="kotlin"
		           implementationClass="biz.paluch.dap.assistant.editor.DependencyVersionAnnotator"/>
		<codeInsight.lineMarkerProvider
				language="Groovy"
				implementationClass="biz.paluch.dap.gradle.GradleLineMarkerProvider"/>
		<codeInsight.lineMarkerProvider
				language="Properties"
				implementationClass="biz.paluch.dap.gradle.GradleLineMarkerProvider"/>
		<codeInsight.lineMarkerProvider
				language="Properties"
				implementationClass="biz.paluch.dap.gradle.wrapper.GradleWrapperLineMarkerProvider"/>
		<codeInsight.lineMarkerProvider
				language="TOML"
				implementationClass="biz.paluch.dap.gradle.GradleLineMarkerProvider"/>
		<codeInsight.lineMarkerProvider
				language="kotlin"
				implementationClass="biz.paluch.dap.gradle.GradleLineMarkerProvider"/>
		<localInspection id="dap.gradle.wrapper.url-inspection"
				language="Properties"
				bundle="messages.MessageBundle"
				groupKey="inspection.gradle-wrapper.group"
				key="inspection.gradle-wrapper.display-name"
				level="WARNING"
				enabledByDefault="true"
				implementationClass="biz.paluch.dap.gradle.wrapper.GradleWrapperUrlInspection"/>
		<intentionAction id="dap.gradle.checksum.distribution">
			<language>Properties</language>
			<categoryKey>intention.dap.category</categoryKey>
			<bundleName>messages.MessageBundle</bundleName>
			<className>biz.paluch.dap.gradle.wrapper.GradleWrapperChecksumIntention</className>
		</intentionAction>
	</extensions>
</idea-plugin>
